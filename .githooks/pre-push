#!/bin/bash
set -e

# ANSI color codes
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${CYAN}--- Running pre-push checks ---${NC}"

# 1. Format check
echo -e "\n${YELLOW}1/4: Checking formatting...${NC}"
if ! cargo fmt -- --check; then
    echo -e "${RED}Error: Code is not formatted. Run 'cargo fmt' to fix.${NC}"
    exit 1
fi
echo -e "${GREEN}Formatting check passed.${NC}"

# 2. Clippy
echo -e "\n${YELLOW}2/4: Running clippy...${NC}"
if ! cargo clippy --all-targets --all-features -- -D warnings; then
    echo -e "${RED}Error: Clippy found issues.${NC}"
    exit 1
fi
echo -e "${GREEN}Clippy check passed.${NC}"

# 3. Tests
echo -e "\n${YELLOW}3/4: Running tests...${NC}"
if ! cargo test --workspace -- --nocapture; then
    echo -e "${RED}Error: Tests failed.${NC}"
    exit 1
fi
echo -e "${GREEN}All tests passed.${NC}"

# 4. Cargo Deny
echo -e "\n${YELLOW}4/4: Checking for denied dependencies...${NC}"
if ! cargo deny check; then
    echo -e "${RED}Error: cargo-deny found issues.${NC}"
    exit 1
fi
echo -e "${GREEN}cargo-deny check passed.${NC}"

echo -e "\n${GREEN}--- All checks passed. Proceeding with push. ---${NC}"
exit 0

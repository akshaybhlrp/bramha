{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Pure Rust API (Release Mode)",
            "type": "shell",
            "command": "cargo run --release",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build"
        }
    ]
}
